---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PASSWORD } from '../lib/auth';
---

<BaseLayout title="访问验证">
  <div class="page">
    <div class="container-narrow">
      <div class="card" style="max-width: 400px; margin: 80px auto;">
        <h2 style="margin-bottom: var(--space-sm);">工作脉络</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: var(--space-lg);">
          请输入访问密码
        </p>
        <input
          type="password"
          id="pwd"
          class="search-input"
          placeholder="输入密码..."
          onkeydown="if(event.key==='Enter')checkPwd()"
        />
        <button onclick="checkPwd()" class="btn btn-primary" style="margin-top: var(--space-md); width: 100%;">
          验证
        </button>
        <p id="error" style="color: var(--color-danger); display: none; margin-top: var(--space-sm); font-size: var(--font-size-sm);">
          密码错误，请重试
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script type="application/json" id="auth-config">
{JSON.stringify({ password: PASSWORD })}
</script>

<script is:inline>
  const configEl = document.getElementById('auth-config');
  const config = JSON.parse(configEl?.textContent || '{}');
  const PASSWORD = config.password || '';

  function checkPwd() {
    const input = document.getElementById('pwd');
    const errorEl = document.getElementById('error');
    if (input.value === PASSWORD) {
      sessionStorage.setItem('worktrace_auth', '1');
      location.href = '/';
    } else {
      if (errorEl) errorEl.style.display = 'block';
      input.value = '';
      input.focus();
    }
  }
</script>

<style>
  .page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
