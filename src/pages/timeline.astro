---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Timeline from '../components/Timeline';

const meetings = await getCollection('meetings');

// ── 按日期升序排列，映射为 Timeline 所需字段 ──
const meetingItems = meetings
  .map((m) => ({
    id: m.id,
    title: m.data.metadata.title,
    date: m.data.metadata.date,
    summary: m.data.summary ?? '',
  }))
  .sort((a, b) => a.date.localeCompare(b.date));

const dateMin = meetingItems.at(0)?.date ?? '?';
const dateMax = meetingItems.at(-1)?.date ?? '?';
---

<BaseLayout title="时间线" description="23 场会议交互时间线">
  <div class="page">
    <!-- ═══════════ Hero ═══════════ -->
    <section class="hero">
      <div class="container">
        <h1 class="hero-title">会议时间线</h1>
        <p class="hero-sub">
          {meetingItems.length} 场会议 · {dateMin} → {dateMax}
        </p>
      </div>
    </section>

    <div class="container-wide">
      <!-- ═══════════ Timeline Island ═══════════ -->
      <section class="timeline-section">
        <div class="card timeline-card">
          <Timeline meetings={meetingItems} client:load />
        </div>
        <p class="hint">
          拖拽/滚轮缩放时间轴 · 悬停查看摘要 · 点击进入会议详情
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-bottom: var(--space-3xl);
  }

  /* ── Hero ── */
  .hero {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    padding: var(--space-3xl) 0;
    margin-bottom: var(--space-2xl);
  }

  .hero-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: var(--space-sm);
  }

  .hero-sub {
    font-size: var(--font-size-lg);
    color: var(--color-accent-light);
    margin-bottom: 0;
  }

  /* ── Timeline section ── */
  .timeline-section {
    margin-bottom: var(--space-lg);
  }

  .timeline-card {
    padding: 0;
    overflow: hidden;
  }

  .timeline-card :global(.timeline-wrapper) {
    height: 600px;
  }

  .timeline-card :global(.timeline-container) {
    width: 100%;
    height: 100%;
  }

  .timeline-card :global(.timeline-status) {
    text-align: center;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    padding: var(--space-sm) 0;
    background: var(--color-surface-hover);
  }

  .hint {
    text-align: center;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-md);
  }

  @media (max-width: 767px) {
    .hero-title {
      font-size: var(--font-size-2xl);
    }
  }
</style>
