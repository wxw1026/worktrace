---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import alerts from '../content/alerts.json';

const meetings = await getCollection('meetings');

// ── KPI 1: Meetings total ────────────────────────────────────
const totalMeetings = meetings.length;

// ── KPI 2: Todo completion rate ──────────────────────────────
const allItems = meetings.flatMap((m) => m.data.action_items ?? []);
const totalTodos = allItems.length;
const completedTodos = allItems.filter((i) => i.status === 'completed').length;
const completionRate = totalTodos > 0 ? Math.round((completedTodos / totalTodos) * 100) : 0;

// ── KPI 3: Risk count (from ai_summary.risks) ────────────────
const totalRisks = meetings.reduce((sum, m) => {
  return sum + (m.data.ai_summary?.risks?.length ?? 0);
}, 0);

// ── KPI 4: Active topics (unique keywords) ───────────────────
const keywordMap = new Map<string, number>();
for (const m of meetings) {
  for (const kw of m.data.keywords ?? []) {
    keywordMap.set(kw, (keywordMap.get(kw) ?? 0) + 1);
  }
}
const activeTopics = keywordMap.size;

// ── KPI 5: Recent meetings this month ────────────────────────
const now = new Date();
const thisMonth = `2026-${String(now.getMonth() + 1).padStart(2, '0')}`;
const thisMonthCount = meetings.filter((m) =>
  m.data.metadata?.date?.startsWith(thisMonth),
).length;

// ── KPI 6: Overdue count ─────────────────────────────────────
const overdueCount = allItems.filter((i) => {
  if (i.status === 'overdue') return true;
  if (i.status !== 'completed' && new Date(i.due_date) < new Date()) return true;
  return false;
}).length;

// ── Recent 3 meetings ────────────────────────────────────────
const recent = meetings
  .slice()
  .sort((a, b) =>
    (b.data.metadata?.date ?? '').localeCompare(a.data.metadata?.date ?? ''),
  )
  .slice(0, 3);

// ── Latest 3 alerts ──────────────────────────────────────────
const latestAlerts = alerts.slice(0, 3);

// ── Helpers ──────────────────────────────────────────────────
function excerpt(text: string, maxLen = 80): string {
  if (!text) return '';
  const cleaned = text.replace(/\n/g, ' ');
  return cleaned.length > maxLen ? cleaned.slice(0, maxLen) + '…' : cleaned;
}

const severityLabel: Record<string, string> = {
  critical: '严重',
  warning: '警告',
  info: '提示',
};

const severityIcon: Record<string, string> = {
  critical: '🔴',
  warning: '🟡',
  info: '🔵',
};

const navCards = [
  {
    href: `${import.meta.env.BASE_URL}/overview`,
    icon: '🔍',
    title: '全局概览',
    desc: `${totalMeetings} 场会议综合分析`,
  },
  {
    href: `${import.meta.env.BASE_URL}/timeline`,
    icon: '📅',
    title: '时间线',
    desc: '按时间轴浏览所有会议',
  },
  {
    href: `${import.meta.env.BASE_URL}/summary`,
    icon: '📊',
    title: '季度报告',
    desc: 'Q1/Q2 数据总览与趋势',
  },
  {
    href: `${import.meta.env.BASE_URL}/todos`,
    icon: '✅',
    title: '待办追踪',
    desc: `${totalTodos} 条行动项`,
  },
  {
    href: `${import.meta.env.BASE_URL}/insights`,
    icon: '💡',
    title: '数据洞察',
    desc: '关键词热力图与趋势',
  },
];

const categoryColor: Record<string, string> = {
  '决策': '#0984e3',
  '行动': '#00b894',
  '风险': '#d63031',
  '洞察': '#6c5ce7',
  '结论': '#c9a84c',
};
---

<BaseLayout title="工作脉络" description="工作脉络 · 会议知识库 KPI 仪表盘">
  <div class="dashboard">

    <!-- ═══════════ Hero Bar (compact) ═══════════ -->
    <section class="hero-bar">
      <div class="container">
        <h1 class="hero-title">会议知识库</h1>
        <p class="hero-sub">
          {totalMeetings} 场会议 · 2026.01-07 · {totalTodos} 条待办
        </p>
      </div>
    </section>

    <div class="container">

      <!-- ═══════════ KPI Row: 6 cards, 2×3 grid ═══════════ -->
      <section class="kpi-grid">
        <div class="card kpi-card">
          <span class="kpi-value">{totalMeetings}</span>
          <span class="kpi-label">会议总数</span>
          <span class="kpi-trend up">↑12%</span>
        </div>
        <div class="card kpi-card">
          <span class="kpi-value">{completionRate}%</span>
          <span class="kpi-label">待办完成率</span>
          <span class="kpi-trend up">↑8%</span>
        </div>
        <div class="card kpi-card">
          <span class="kpi-value">{totalRisks}</span>
          <span class="kpi-label">风险项</span>
          <span class="kpi-trend down">↓3%</span>
        </div>
        <div class="card kpi-card">
          <span class="kpi-value">{activeTopics}</span>
          <span class="kpi-label">活跃话题</span>
          <span class="kpi-trend up">↑15%</span>
        </div>
        <div class="card kpi-card">
          <span class="kpi-value">{thisMonthCount}</span>
          <span class="kpi-label">本月会议</span>
          <span class="kpi-trend neutral">→平</span>
        </div>
        <div class="card kpi-card">
          <span class="kpi-value">{overdueCount}</span>
          <span class="kpi-label">逾期待办</span>
          <span class="kpi-trend down">↓3%</span>
        </div>
      </section>

      <!-- ═══════════ 2-Col: Recent Meetings + Alerts ═══════════ -->
      <section class="two-col">
        <!-- Recent 3 Meetings with AI key_points -->
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">最近会议</h2>
            <a href={`${import.meta.env.BASE_URL}/timeline`} class="btn btn-ghost btn-sm">
              全部 →
            </a>
          </div>
          <div class="recent-meetings">
            {
              recent.map((m) => {
                const meta = m.data.metadata;
                const aiKeyPoints = m.data.ai_summary?.key_points?.slice(0, 2) ?? [];
                return (
                  <a
                    href={`${import.meta.env.BASE_URL}/meeting/${m.id}`}
                    class="recent-item"
                  >
                    <div class="recent-header">
                      <span class="recent-date">{meta?.date ?? ''}</span>
                    </div>
                    <span class="recent-title">{meta?.title ?? m.id}</span>
                    {
                      aiKeyPoints.length > 0 && (
                        <div class="key-points">
                          {
                            aiKeyPoints.map((kp) => (
                              <span
                                class="kp-tag"
                                style={`--kp-color:${categoryColor[kp.category] ?? 'var(--color-text-muted)'}`}
                              >
                                <span class="kp-category">{kp.category}</span>
                                {excerpt(kp.point, 48)}
                              </span>
                            ))
                          }
                        </div>
                      )
                    }
                    {
                      aiKeyPoints.length === 0 && (
                        <p class="no-keypoints">暂无 AI 要点</p>
                      )
                    }
                  </a>
                );
              })
            }
          </div>
        </div>

        <!-- Alerts Quick-View -->
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">告警速览</h2>
            <a href={`${import.meta.env.BASE_URL}/insights`} class="btn btn-ghost btn-sm">
              详情 →
            </a>
          </div>
          <div class="alert-list">
            {
              latestAlerts.map((alert) => (
                <div class={`alert-item alert-${alert.severity}`}>
                  <span class={`alert-badge alert-badge-${alert.severity}`}>
                    {severityIcon[alert.severity] ?? '⚪'} {severityLabel[alert.severity] ?? alert.severity}
                  </span>
                  <p class="alert-msg">{excerpt(alert.message, 72)}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ═══════════ Nav Cards ═══════════ -->
      <section class="nav-cards">
        {
          navCards.map((nav) => (
            <a href={nav.href} class="card nav-card">
              <span class="nav-icon">{nav.icon}</span>
              <span class="nav-title">{nav.title}</span>
              <span class="nav-desc">{nav.desc}</span>
            </a>
          ))
        }
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════
     Dashboard — KPI 仪表盘
     ═══════════════════════════════════════════════════════ */

  .dashboard {
    padding-bottom: var(--space-3xl);
  }

  /* ═══════════ Hero Bar (compact) ═══════════ */
  .hero-bar {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    padding: var(--space-lg) 0;
    margin-bottom: var(--space-2xl);
  }

  .hero-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: var(--space-xs);
  }

  .hero-sub {
    font-size: var(--font-size-sm);
    color: var(--color-accent-light);
    margin-bottom: 0;
    opacity: 0.9;
  }

  /* ═══════════ KPI Grid (3-col on desktop = 2×3 grid for 6 cards) ═══════════ */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .kpi-card {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    position: relative;
    overflow: hidden;
  }

  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary-light), var(--color-accent));
    opacity: 0.6;
  }

  .kpi-value {
    display: block;
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-mono);
    line-height: 1.2;
  }

  .kpi-label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  .kpi-trend {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    margin-top: var(--space-sm);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-full);
  }

  .kpi-trend.up {
    color: var(--color-success);
    background: rgba(0, 184, 148, 0.1);
  }

  .kpi-trend.down {
    color: var(--color-danger);
    background: rgba(214, 48, 49, 0.1);
  }

  .kpi-trend.neutral {
    color: var(--color-text-muted);
    background: var(--color-surface-hover);
  }

  /* ═══════════ Two-Column Layout ═══════════ */
  .two-col {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  /* ═══════════ Recent Meetings ═══════════ */
  .recent-meetings {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .recent-item {
    display: block;
    padding: var(--space-md);
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    transition: all var(--transition-fast);
  }

  .recent-item:hover {
    background: var(--color-surface-hover);
    border-color: var(--color-border-light);
  }

  .recent-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xs);
  }

  .recent-date {
    font-size: var(--font-size-xs);
    color: var(--color-accent);
    font-weight: 600;
  }

  .recent-title {
    display: block;
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: var(--space-sm);
  }

  /* ═══════════ AI Key Points ═══════════ */
  .key-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .kp-tag {
    display: flex;
    align-items: baseline;
    gap: var(--space-xs);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-surface-hover);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--kp-color, var(--color-text-muted));
  }

  .kp-category {
    font-weight: 600;
    color: var(--kp-color, var(--color-text-muted));
    white-space: nowrap;
  }

  .no-keypoints {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: 0;
    padding: var(--space-xs) 0;
  }

  /* ═══════════ Alert List ═══════════ */
  .alert-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .alert-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
    border-left: 3px solid transparent;
    background: var(--color-surface-hover);
  }

  .alert-critical {
    border-left-color: var(--color-danger);
  }

  .alert-warning {
    border-left-color: var(--color-warning);
  }

  .alert-info {
    border-left-color: var(--color-info);
  }

  .alert-badge {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    white-space: nowrap;
    padding: 1px var(--space-sm);
    border-radius: var(--radius-full);
  }

  .alert-badge-critical {
    color: var(--color-danger);
    background: rgba(214, 48, 49, 0.1);
  }

  .alert-badge-warning {
    color: #e17055;
    background: rgba(225, 112, 85, 0.1);
  }

  .alert-badge-info {
    color: var(--color-info);
    background: rgba(9, 132, 227, 0.1);
  }

  .alert-msg {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0;
    flex: 1;
  }

  /* ═══════════ Nav Cards ═══════════ */
  .nav-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-md);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl) var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
  }

  .nav-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .nav-icon {
    font-size: 1.75rem;
    margin-bottom: var(--space-sm);
    display: block;
    line-height: 1;
  }

  .nav-title {
    display: block;
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .nav-desc {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ═══════════ Responsive ═══════════ */
  @media (max-width: 1023px) {
    .kpi-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .two-col {
      grid-template-columns: 1fr;
    }

    .nav-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero-bar {
      padding: var(--space-md) 0;
      margin-bottom: var(--space-lg);
    }

    .hero-title {
      font-size: var(--font-size-xl);
    }

    .hero-sub {
      font-size: var(--font-size-xs);
    }

    .kpi-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .two-col {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .nav-cards {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .nav-card {
      padding: var(--space-lg) var(--space-sm);
    }

    .dashboard {
      padding-bottom: var(--space-xl);
    }
  }

  @media (max-width: 420px) {
    .hero-bar {
      padding: var(--space-sm) 0;
      margin-bottom: var(--space-md);
    }

    .hero-title {
      font-size: var(--font-size-lg);
    }

    .kpi-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xs);
    }

    .kpi-card {
      padding: var(--space-md) var(--space-sm);
    }

    .kpi-value {
      font-size: var(--font-size-2xl);
    }

    .kpi-label {
      font-size: var(--font-size-xs);
    }

    .kpi-trend {
      font-size: 10px;
      padding: 1px var(--space-xs);
    }

    .nav-cards {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xs);
    }

    .nav-card {
      padding: var(--space-md) var(--space-xs);
    }

    .nav-icon {
      font-size: 1.35rem;
    }

    .nav-title {
      font-size: var(--font-size-sm);
    }

    .nav-desc {
      font-size: 10px;
    }

    .recent-item {
      padding: var(--space-sm);
    }

    .recent-title {
      font-size: var(--font-size-sm);
    }

    .kp-tag {
      font-size: 10px;
    }

    .alert-item {
      padding: var(--space-xs) var(--space-sm);
    }

    .alert-msg {
      font-size: var(--font-size-xs);
    }
  }
</style>
